# ─── Server ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/us_always
JWT_ACCESS_SECRET=your_super_secret_access_token_here_change_in_production
JWT_REFRESH_SECRET=your_super_secret_refresh_token_here_change_in_production
PORT=3001
